<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_auto_pay_invoices" model="ir.cron">
        <field name="name">Auto Payment: Process Automatic Payments</field>
        <field name="model_id" ref="model_auto_payment_config"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_pay_invoices()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=7, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active">True</field>
    </record>
</odoo>
