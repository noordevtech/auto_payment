<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="auto_payment_config_view_tree" model="ir.ui.view">
        <field name="name">auto.payment.config.tree</field>
        <field name="model">auto.payment.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="payment_day"/>
                <field name="journal_id"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="auto_payment_config_view_form" model="ir.ui.view">
        <field name="name">auto.payment.config.form</field>
        <field name="model">auto.payment.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group string="Client">
                            <field name="partner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Payment Settings">
                            <field name="payment_day"
                                   help="Day of the month (1-28) when payments are processed"/>
                            <field name="journal_id"/>
                            <field name="payment_method_line_id"
                                   domain="[('journal_id', '=', journal_id), ('payment_type', '=', 'inbound')]"
                                   optional="show"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="auto_payment_config_view_search" model="ir.ui.view">
        <field name="name">auto.payment.config.search</field>
        <field name="model">auto.payment.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="journal_id"/>
                <filter name="inactive" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_partner"
                            string="Client"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_day"
                            string="Payment Day"
                            context="{'group_by': 'payment_day'}"/>
                    <filter name="group_by_journal"
                            string="Journal"
                            context="{'group_by': 'journal_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="auto_payment_config_action" model="ir.actions.act_window">
        <field name="name">Auto Payments</field>
        <field name="res_model">auto.payment.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="auto_payment_config_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first auto payment configuration
            </p>
            <p>
                Configure automatic payments for specific clients on a monthly schedule.
                Set the day of the month and the payment journal, and invoices will be
                paid automatically.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="auto_payment_menu_root"
              name="Auto Payments"
              parent="account.menu_finance_configuration"
              action="auto_payment_config_action"
              sequence="100"/>

</odoo>
